{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "pg chart values (enum guards)",
  "description": "Partial schema: constrains the values whose typos silently misconfigure HA. additionalProperties stays open so the rest of values.yaml is unconstrained.",
  "type": "object",
  "properties": {
    "postgresql": {
      "type": "object",
      "properties": {
        "roles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
              "login": { "type": "boolean" },
              "passwordSecret": {
                "type": "object",
                "properties": { "name": { "type": "string" }, "key": { "type": "string" } }
              },
              "memberOf": { "type": "array", "items": { "type": "string" } },
              "grants": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["database", "privileges"],
                  "properties": {
                    "database": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
                    "schema": { "type": "string" },
                    "objects": { "enum": ["", "ALL_TABLES", "ALL_SEQUENCES"] },
                    "privileges": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
                  }
                }
              }
            }
          }
        },
        "databases": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
              "owner": { "type": "string" },
              "extensions": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "repmgr": {
      "type": "object",
      "properties": {
        "failoverMode": {
          "enum": ["repmgrd", "agent"],
          "description": "repmgrd (default) or the lease-based Go agent."
        },
        "agent": {
          "type": "object",
          "properties": {
            "dcs": {
              "type": "object",
              "properties": {
                "backend": {
                  "enum": ["kubernetes", "etcd"],
                  "description": "Leadership store: the Kubernetes Lease API (default) or etcd."
                }
              }
            }
          }
        },
        "splitBrainDetection": {
          "type": "object",
          "properties": {
            "action": {
              "enum": ["log", "fence"]
            }
          }
        }
      }
    },
    "pgpool": {
      "type": "object",
      "properties": {
        "tls": {
          "type": "object",
          "properties": {
            "backendSslmode": {
              "enum": ["disable", "prefer", "require", "verify-ca", "verify-full"],
              "description": "libpq sslmode for pgpool -> postgres backend connections. Must be >= require when postgresql.tls.require is true."
            }
          }
        }
      }
    },
    "prometheusExporter": {
      "type": "object",
      "properties": {
        "sslmode": {
          "enum": ["disable", "require", "verify-ca", "verify-full"],
          "description": "libpq sslmode for the exporter -> postgres connection. Must be >= require when postgresql.tls.require is true."
        }
      }
    },
    "pgbackrest": {
      "type": "object",
      "properties": {
        "s3": {
          "type": "object",
          "properties": {
            "keyType": {
              "enum": ["shared", "auto"],
              "description": "shared = static keys from existingSecret; auto = cloud workload identity / instance credential chain."
            },
            "uriStyle": {
              "enum": ["host", "path"],
              "description": "S3 addressing: host (AWS virtual-host style, default) or path (most non-AWS stores)."
            }
          }
        },
        "repoEncryption": {
          "type": "object",
          "properties": {
            "cipherType": {
              "enum": ["aes-256-cbc", "none"],
              "description": "pgBackRest repo1-cipher-type when repoEncryption.enabled."
            }
          }
        },
        "validation": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "schedule": { "type": "string" },
            "targetType": {
              "enum": ["", "time", "xid", "name", "lsn"],
              "description": "PITR target type (pgbackrest --type); empty restores the latest backup + replays all WAL. validation.target is required when set."
            },
            "target": { "type": "string" },
            "recoveryTimeout": { "type": "integer" },
            "workdirSizeLimit": { "type": "string" },
            "activeDeadlineSeconds": { "type": "integer" },
            "backoffLimit": { "type": "integer" }
          }
        }
      }
    }
  }
}
