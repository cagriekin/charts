{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "redis chart values (enum guards)",
  "description": "Partial schema: constrains the values whose typos silently misconfigure Redis. additionalProperties stays open so the rest of values.yaml is unconstrained.",
  "type": "object",
  "properties": {
    "architecture": {
      "enum": ["standalone", "replication"]
    },
    "redis": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "pullPolicy": {
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "replicaCount": {
          "type": "integer",
          "minimum": 0
        },
        "auth": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "acl": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "operatorUser": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9_.-]+$"
                },
                "users": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name"],
                    "properties": {
                      "name": {
                        "type": "string",
                        "pattern": "^[A-Za-z0-9_.-]+$"
                      },
                      "rules": {
                        "type": "string"
                      },
                      "passwordSecret": {
                        "type": "object",
                        "properties": {
                          "name": { "type": "string" },
                          "key": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "config": {
          "type": "object",
          "properties": {
            "maxmemory-policy": {
              "enum": [
                "noeviction",
                "allkeys-lru",
                "allkeys-lfu",
                "allkeys-random",
                "volatile-lru",
                "volatile-lfu",
                "volatile-random",
                "volatile-ttl"
              ]
            },
            "appendfsync": {
              "enum": ["always", "everysec", "no"]
            },
            "min-replicas-to-write": {
              "type": "integer",
              "minimum": 0
            },
            "min-replicas-max-lag": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "sentinel": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "pullPolicy": {
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "service": {
          "type": "object",
          "properties": {
            "type": {
              "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"]
            }
          }
        }
      }
    },
    "tls": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "existingSecret": {
          "type": "string"
        },
        "clientCertAuth": {
          "type": "boolean"
        }
      }
    },
    "exporter": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "pullPolicy": {
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "service": {
          "type": "object",
          "properties": {
            "type": {
              "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"]
            }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"]
        }
      }
    }
  }
}
